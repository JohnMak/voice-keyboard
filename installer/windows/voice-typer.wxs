<?xml version="1.0" encoding="UTF-8"?>

<!--
  Voice Typer - Windows MSI Installer

  Built with WiX Toolset v5
  https://wixtoolset.org/

  Features:
  - Clean install and upgrade support
  - Automatic removal of previous versions
  - Start Menu shortcut
  - Optional PATH registration
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Voice Typer"
           Manufacturer="Alex Mak"
           Version="$(ProductVersion)"
           UpgradeCode="8A5E7B3C-1F2D-4E6A-9B8C-0D1E2F3A4B5C"
           Compressed="yes">

    <SummaryInformation Description="Voice to text using local Whisper AI"
                        Manufacturer="Alex Mak" />

    <!-- Upgrade handling - removes previous versions -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Voice Typer is already installed."
                  AllowSameVersionUpgrades="yes" />

    <Media Id="1" Cabinet="VoiceTyper.cab" EmbedCab="yes" />

    <!-- Installation directory -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Voice Typer">
        <Component Id="MainExecutable" Guid="1A2B3C4D-5E6F-7A8B-9C0D-1E2F3A4B5C6D">
          <File Id="VoiceTyperExe"
                Source="$(BinaryPath)"
                Name="voice-typer.exe"
                KeyPath="yes" />

          <!-- Add to PATH (optional) -->
          <Environment Id="PATH"
                       Name="PATH"
                       Value="[INSTALLFOLDER]"
                       Permanent="no"
                       Part="last"
                       Action="set"
                       System="yes" />
        </Component>

        <!-- README file -->
        <Component Id="ReadmeFile" Guid="2B3C4D5E-6F7A-8B9C-0D1E-2F3A4B5C6D7E">
          <File Id="ReadmeTxt"
                Source="installer/windows/README.txt"
                Name="README.txt" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcuts -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Voice Typer">
        <Component Id="StartMenuShortcuts" Guid="3C4D5E6F-7A8B-9C0D-1E2F-3A4B5C6D7E8F">
          <Shortcut Id="VoiceTyperShortcut"
                    Name="Voice Typer"
                    Description="Voice to text using local Whisper AI"
                    Target="[INSTALLFOLDER]voice-typer.exe"
                    WorkingDirectory="INSTALLFOLDER" />

          <Shortcut Id="UninstallShortcut"
                    Name="Uninstall Voice Typer"
                    Description="Uninstall Voice Typer"
                    Target="[SystemFolder]msiexec.exe"
                    Arguments="/x [ProductCode]" />

          <RemoveFolder Id="CleanUpShortcuts" Directory="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\VoiceTyper" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Feature definition -->
    <Feature Id="Complete" Level="1" Title="Voice Typer" Description="Complete installation">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ReadmeFile" />
      <ComponentRef Id="StartMenuShortcuts" />
    </Feature>

    <!-- Standard UI -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- License -->
    <WixVariable Id="WixUILicenseRtf" Value="installer/windows/LICENSE.rtf" />

  </Package>
</Wix>
