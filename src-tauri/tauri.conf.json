{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Keyboard",
  "version": "0.1.0",
  "identifier": "com.alexmak.voice-keyboard",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "title": "Voice Keyboard",
        "label": "main",
        "width": 500,
        "height": 600,
        "resizable": true,
        "visible": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
